# =============================================
# AquaApp - Omgevingsvariabelen
# Kopieer dit bestand naar .env en vul in
# =============================================

# Server poort (Hostinger gebruikt vaak process.env.PORT automatisch)
PORT=3000

# JWT geheime sleutel - verander dit naar iets unieks!
JWT_SECRET=verander-dit-naar-een-lange-willekeurige-string

# ---- SMTP E-mail instellingen ----
# Voor Gmail: schakel "App-wachtwoord" in via Google Account instellingen
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=jouw-email@gmail.com
SMTP_PASS=jouw-app-wachtwoord
SMTP_FROM=AquaApp <jouw-email@gmail.com>

# Voor Hostinger e-mail:
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@jouwdomein.nl
# SMTP_PASS=jouw-e-mail-wachtwoord
# SMTP_FROM=AquaApp <noreply@jouwdomein.nl>
